# ──────────────────────────────────────────────
# Echo-Sync  —  Environment Configuration
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# ──────────────────────────────────────────────

# OpenAI API key (required for STT and AI intent classification)
OPENAI_API_KEY=your_api_key_here

# Speech-to-text mode: "openai" or "offline"
ECHO_SYNC_STT_MODE=openai

# AI model for intent classification
ECHO_SYNC_AI_MODEL=gpt-4o-mini

# Speech-to-text model
ECHO_SYNC_STT_MODEL=gpt-4o-mini-transcribe

# Media player backend: "vlc" or "pygame"
ECHO_SYNC_PLAYER=vlc

# Default music volume (0-100)
ECHO_SYNC_DEFAULT_VOLUME=80

# Volume level during ducking (0-100)
ECHO_SYNC_DUCKING_VOLUME=30

# Silence timeout in seconds before guided help triggers
ECHO_SYNC_SILENCE_TIMEOUT=10

# Confidence threshold below which AI results trigger clarification
ECHO_SYNC_CONFIDENCE_THRESHOLD=0.6

# The wake word to activate the system (e.g. 'echo')
# If empty, the system will process all speech.
ECHO_SYNC_WAKE_WORD=echo

# Path to music assets (relative to project root)
ECHO_SYNC_MUSIC_DIR=assets/music

# Path to earcon assets (relative to project root)
ECHO_SYNC_EARCONS_DIR=assets/earcons

# Log file path
ECHO_SYNC_LOG_FILE=logs/interaction_logs.csv
